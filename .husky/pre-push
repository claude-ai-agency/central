#!/usr/bin/env bash
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
echo "🧪 Pre-push Tests für Branch: $BRANCH"

if [[ "$BRANCH" == "main" || "$BRANCH" == "develop" ]]; then
  echo "→ Schutz-Branch — vollständige Tests..."

  if command -v npm &>/dev/null && [ -f "package.json" ]; then
    if grep -q '"test"' package.json 2>/dev/null; then
      npm test -- --passWithNoTests 2>/dev/null || {
        echo "❌ Tests fehlgeschlagen — Push blockiert"
        echo "Fix: npm test"
        exit 1
      }
    fi
  fi

  if [ -f "pytest.ini" ] || ([ -f "pyproject.toml" ] && grep -q "pytest" pyproject.toml 2>/dev/null); then
    python -m pytest -q --tb=short 2>/dev/null || {
      echo "❌ Python Tests fehlgeschlagen"
      exit 1
    }
  fi

  echo "✅ Tests grün — Push erlaubt"
else
  echo "→ Feature-Branch — kein Test-Gate"
fi
